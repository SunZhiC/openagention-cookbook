    "ch10": "pnpm --filter @openagention/examples run ch10",
    "ch11": "pnpm --filter @openagention/examples run ch11",
    "ch12": "pnpm --filter @openagention/examples run ch12",
    "ch13": "pnpm --filter @openagention/examples run ch13",
    "ch14": "pnpm --filter @openagention/examples run ch14",
    "ch15": "pnpm --filter @openagention/examples run ch15",
    "ch16": "pnpm --filter @openagention/examples run ch16",
    "ch17": "pnpm --filter @openagention/examples run ch17",
